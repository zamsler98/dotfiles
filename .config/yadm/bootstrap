#!/usr/bin/env bash

set -euo pipefail

PACKAGES_DIR="$HOME/.config/yadm/packages"
PACMAN_PACKAGES_FILE="$PACKAGES_DIR/pacman.txt"
NPM_GLOBALS_FILE="$PACKAGES_DIR/npm-globals.txt"

read_package_list() {
    local file="$1"
    local -n packages_ref="$2"
    local line

    packages_ref=()

    [[ -f "$file" ]] || return 0

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line//[[:space:]]/}" ]] && continue
        packages_ref+=("$line")
    done < "$file"
}

echo "==> Installing pacman packages..."
if ! command -v pacman &>/dev/null; then
    echo "Error: pacman is required to run this bootstrap script"
    exit 1
fi

read_package_list "$PACMAN_PACKAGES_FILE" pacman_packages
if (( ${#pacman_packages[@]} > 0 )); then
    sudo pacman -S --needed "${pacman_packages[@]}"
else
    echo "No pacman packages listed; skipping"
fi

echo "==> Installing nvm..."
if [[ ! -d "$HOME/.nvm" ]]; then
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/HEAD/install.sh | bash
fi

export NVM_DIR="$HOME/.nvm"
# shellcheck source=/dev/null
[[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
if ! command -v nvm &>/dev/null; then
    echo "Error: nvm is not available after installation"
    exit 1
fi

echo "==> Installing Node LTS..."
nvm install --lts
nvm use --lts

echo "==> Installing npm globals..."
read_package_list "$NPM_GLOBALS_FILE" npm_globals
if (( ${#npm_globals[@]} > 0 )); then
    npm install -g "${npm_globals[@]}"
else
    echo "No npm globals listed; skipping"
fi

echo "==> Done!"
